# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///zerorukawat_dev.db

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# ── External APIs ─────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweathermap-api-key-here
AI_SERVER_URL=http://localhost:5001

# ── Internal Security ─────────────────────────────────────────────────────────
INTERNAL_API_KEY=dev-internal-key-123

# ── OTP Settings ───────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_MINUTES=10

# ── Twilio SMS (required in production) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Prefer Verify Service SID (from twilio_setup style flow)
TWILIO_VERIFY_SERVICE_SID=
# Optional if using Programmable SMS instead of Verify Service
TWILIO_FROM_NUMBER=+10000000000

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
